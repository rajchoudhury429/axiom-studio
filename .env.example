# Web3Forms access key (client-side — safe to expose in browser bundle)
# Web3Forms access keys are form identifiers, not secrets.
VITE_WEB3FORMS_ACCESS_KEY=your_web3forms_access_key_here

# Server-side Web3Forms key (NITRO_ prefix for runtime availability)
NITRO_WEB3FORMS_ACCESS_KEY=your_web3forms_access_key_here

# Groq API key for AI chat assistant
GROQ_API_KEY=your_groq_api_key_here
NITRO_GROQ_API_KEY=your_groq_api_key_here
VITE_GROQ_API_KEY=your_groq_api_key_here
