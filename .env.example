# Web3Forms access key (server-only secret — never exposed to the client)
# Get one at https://web3forms.com
# NITRO_ prefix guarantees the var is available at runtime in production builds.
NITRO_WEB3FORMS_ACCESS_KEY=your_web3forms_access_key_here

# Groq API key for AI chat assistant
# Get one at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
